{
  "name": "@scutum/geo",
  "version": "0.1.0",
  "description": "Geospatial primitives for defense infrastructure mapping, zone classification, and threat corridor projection",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --strict"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ScutumDefense/scutum-geo.git"
  },
  "keywords": [
    "geospatial",
    "defense",
    "zones",
    "corridors",
    "proximity",
    "haversine",
    "threat-corridor",
    "mercator"
  ]
}
